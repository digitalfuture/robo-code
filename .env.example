# Robot Connection Settings
# ==========================
# Copy this file to .env and configure for your robot

# Robot IP address
VITE_ROBOT_IP=192.168.60.68

# Robot Ports - Both can be configured:
VITE_ROBOT_PORT_MODBUS=1502    # Modbus TCP (read coordinates/joints)
VITE_ROBOT_PORT_TCP=5000       # TCP String Protocol (commands)

# Active port (default: 1502 - Modbus TCP for Estun ERC3-C1)
# Switch to 5000 in UI if TCP String Protocol is needed
VITE_ROBOT_PORT=1502

# WebSocket Proxy Server
VITE_PROXY_URL=ws://localhost:3000
VITE_PROXY_PORT=3000
